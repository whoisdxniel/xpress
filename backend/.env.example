# Server
PORT=3001
CORS_ORIGIN=http://localhost:19006

# Auth
# Min 20 chars
JWT_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME
JWT_EXPIRES_IN=7d

# Database (Postgres / Neon)
# Neon suele darte 2 URLs:
# - Pooled (para runtime): va en DATABASE_URL
# - Direct (para migraciones): va en DIRECT_URL (opcional pero recomendado)
# Ejemplo:
# postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Opcional (recomendado en Neon): conexión directa para `prisma migrate deploy`
DIRECT_URL=

# Prisma migrate dev (solo local). En producción normalmente NO hace falta.
# SHADOW_DATABASE_URL=

# Uploads (Cloudinary) - requerido en Railway si querés persistencia
# Si NO se define, el backend cae a uploads locales (no recomendado en Railway)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opcional
# CLOUDINARY_FOLDER=xpress

# WhatsApp
WHATSAPP_DEFAULT_COUNTRY_CODE=58

# FCM (opcional: usa uno de los dos)
# FCM_SERVICE_ACCOUNT_PATH=
# FCM_SERVICE_ACCOUNT_JSON=

# Feature flags
ENABLE_DRIVER_CREDIT_CHARGE=false

# Routing (opcional)
# OSRM_BASE_URL=https://router.project-osrm.org

# Tarifa / taxímetro
METER_INCLUDED_KM=3
