# Base URL del backend (debe incluir /api)
# Ejemplo: https://api.tudominio.com/api
EXPO_PUBLIC_API_BASE_URL=

# Mapbox
# Token de acceso (runtime) usado por la app (JS).
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# Token de descargas (build-time) para resolver dependencias Android desde el repo Maven de Mapbox.
# Se usa en Gradle como `MAPBOX_DOWNLOADS_TOKEN`.
MAPBOX_DOWNLOADS_TOKEN=sk.YOUR_MAPBOX_DOWNLOADS_TOKEN
